# LAMMPS input script for ReaxFF simulation
# Generated by PoreReax package
{% if SIMNUMBER == 0 %}
boundary p p p
units real
atom_style full
read_data system.data
{% else %}
read_restart run_{{ SIMNUMBER - 1 }}.data
{% endif %}
pair_style reaxff NULL safezone 3.0 mincap 150
pair_coeff * * reax.ffield {{ ATOMS }}
fix myqeq all qeq/reaxff 1 0.0 10.0 1.0e-6 reaxff maxiter 400

timestep {{ TIMESTEP }}

thermo {{ THERMO_FREQ }}
thermo_style custom step temp press pe ke etotal vol density
dump trajdump all custom {{ DUMP_FREQ }} run_{{ SIMNUMBER }}.lammpstrj id type x y z vx vy vz
fix myspec all reaxff/species 1 1 {{ DUMP_FREQ }} run_{{ SIMNUMBER }}.species element {{ ATOMS }}
fix bond all reaxff/bonds {{ DUMP_FREQ }} run_{{ SIMNUMBER }}.bonds
fix removeMom all momentum 100 linear 1 1 1 rescale
{% if SIMULATIONTYPE == "nvt" %}
fix nvt all nvt temp {{ TEMP }} {{ TEMP }} 100.0
{% elif SIMULATIONTYPE == "npt" %}
fix npt all npt temp {{ TEMP }} {{ TEMP }} 100.0 iso {{ PRESS }} {{ PRESS }} 1000.0
{% elif SIMULATIONTYPE == "nve" %}
fix nve all nve
{% endif %}
{% if IMAGE_DUMP_ENABLED -%}
variable img_xmid equal 0.5*(xlo+xhi)
variable img_ymid equal 0.5*(ylo+yhi)
variable img_zmid equal 0.5*(zlo+zhi)
region image_half_xy block INF INF INF INF INF ${img_zmid} units box
region image_half_xz block INF INF ${img_ymid} INF INF INF units box
region image_half_yz block INF ${img_xmid} INF INF INF INF units box
{% for image in IMAGE_DUMPS %}
dump imagedump_{{ image.dump_id }} all image {{ image.dump_freq }} figures/run_{{ SIMNUMBER }}_image_{{ image.dump_id }}_{{ image.plane }}-*.jpg {{ image.type }} type size {{ image.image_width }} {{ image.image_height }} view {{ image.view_theta }} {{ image.view_phi }} center s {{ image.center_x }} {{ image.center_y }} {{ image.center_z }} zoom {{ image.zoom }} {{ image.kwargs }}
dump_modify imagedump_{{ image.dump_id }} region {{ image.region_id }}
{%- if image.color_modify %}
{{ image.color_modify }}
{%- endif -%}
{%- if image.size_modify %}
{{ image.size_modify }}
{%- endif -%}
{% endfor -%}
{% endif %}

run {{ NSTEPS }}

undump trajdump
unfix myspec
unfix bond
unfix removeMom
{% if SIMULATIONTYPE == "npt" %}
unfix npt
{% elif SIMULATIONTYPE == "nve" %}
unfix nve
{% elif SIMULATIONTYPE == "nvt" %}
unfix nvt
{% endif %}
{% if IMAGE_DUMP_ENABLED -%}
{% for image in IMAGE_DUMPS -%}
undump imagedump_{{ image.dump_id }}
{% endfor %}
{% endif -%}
write_restart run_{{ SIMNUMBER }}.data

